# Local development uses a project-relative SQLite database.
# Docker Compose overrides this with file:/app/data/prod.db.
DATABASE_URL="file:./dev.db"

# Required in every environment. Use a long random value of at least 24 characters.
AUTH_SECRET="replace-with-a-long-random-secret"

# Required admin login identity.
ADMIN_EMAIL="admin@example.com"

# Required in production. Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH="scrypt$16384$8$1$example-salt$example-key"
