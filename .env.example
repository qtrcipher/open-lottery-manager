# Local development uses a project-relative SQLite database.
# Docker Compose production templates override this with file:/app/data/prod.db.
DATABASE_URL="file:./dev.db"

# Required in every environment. Use a unique random value of at least 24 characters.
AUTH_SECRET="replace-with-a-long-random-secret"

# Required admin login identity.
ADMIN_EMAIL="admin@example.com"

# Optional public URL shown in admin status and useful for deployment checks.
PUBLIC_APP_URL="https://lottery.example.com"

# Optional. Set to true only when the app is behind a trusted reverse proxy
# that controls x-forwarded-for, x-real-ip, or cf-connecting-ip.
TRUST_PROXY_HEADERS="false"

# Required in production. Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH="scrypt$16384$8$1$example-salt$example-key"

# Optional SMTP ticket receipts. Public entries still work when these are empty.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Optional Cloudflare Turnstile public-entry challenge.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
